---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SignupForm from '@/components/SignupForm.astro'

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`
---

<BaseLayout
  title="YIMBY Adelaide"
  description="YIMBY Adelaide is the local voice for more homes, better choices, and a fairer city."
>
  <main>
    <section class="hero">
      <div class="hero__content">
        <p class="eyebrow">YIMBY Adelaide</p>
        <h1>More homes. Better choices. A fairer Adelaide.</h1>
        <p>
          We are building a strong local voice for abundant, affordable, well-located homes close
          to jobs, schools, services, transport, and community.
        </p>
        <div class="actions">
          <a class="button" href="#signup">Join the movement</a>
          <a class="button button--secondary" href={`${base}about#planning-map-title`}>Explore the map</a>
        </div>
      </div>
    </section>

    <section class="section split home-intro">
      <div>
        <p class="eyebrow">Why We Exist</p>
        <h2>Adelaide needs a positive voice for more homes.</h2>
      </div>
      <div class="copy-stack">
        <p>
          Adelaide is no longer the affordable city many of us remember. Rents and house prices
          are locking people out of the neighbourhoods and opportunities that shape their lives.
        </p>
        <p>
          YIMBY Adelaide makes the case for practical planning reform and more housing choices in
          the well-located places where people already want to live.
        </p>
        <a class="text-link" href={`${base}about`}>Why we started YIMBY Adelaide →</a>
      </div>
    </section>

    <section class="section home-priorities" aria-labelledby="home-priorities-title">
      <div class="section__header">
        <p class="eyebrow">What We Do</p>
        <h2 id="home-priorities-title">Turn support for housing into a visible civic voice.</h2>
      </div>
      <div class="home-feature-grid">
        <article>
          <span>01</span>
          <h3>Make the case</h3>
          <p>Explain why more housing supply and better planning matter for affordability and opportunity.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Show the rules</h3>
          <p>Turn complex planning controls into clear maps, explainers, and practical reform ideas.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Mobilise supporters</h3>
          <p>Help residents speak up through submissions, campaigns, events, and public debate.</p>
        </article>
      </div>
    </section>

    <section class="home-map-feature">
      <div>
        <p class="eyebrow">Explore the Rules</p>
        <h2>See what Adelaide allows, parcel by parcel.</h2>
        <p>
          Compare minimum subdivision sizes and maximum building heights across metropolitan
          Adelaide with our interactive planning map.
        </p>
        <a class="button" href={`${base}about#planning-map-title`}>Open the planning map</a>
      </div>
      <div class="home-map-feature__layers" aria-label="Available planning map layers">
        <article>
          <span class="home-map-feature__swatch home-map-feature__swatch--lots" aria-hidden="true"></span>
          <div><strong>Subdivision</strong><span>Minimum lot-size controls</span></div>
        </article>
        <article>
          <span class="home-map-feature__swatch home-map-feature__swatch--height" aria-hidden="true"></span>
          <div><strong>Building height</strong><span>Maximum designated storeys</span></div>
        </article>
      </div>
    </section>

    <section class="section support-preview" id="get-involved">
      <div class="section__header">
        <p class="eyebrow">Get Involved</p>
        <h2>Choose the pathway that suits you.</h2>
        <p>Stay informed through email updates or become a member of YIMBY Adelaide.</p>
      </div>
      <div class="support-grid">
        <article>
          <p class="eyebrow">Stay Connected</p>
          <h3>Subscribe</h3>
          <p>Receive campaign updates, event invitations, and practical ways to take action.</p>
          <a class="text-link" href="#signup">Join the email list →</a>
        </article>
        <article>
          <p class="eyebrow">Go Deeper</p>
          <h3>Become a member</h3>
          <p>Register your interest in helping shape and sustain YIMBY Adelaide’s work.</p>
          <a class="text-link" href={`${base}membership#become-a-member`}>Become a member →</a>
        </article>
      </div>
    </section>

    {/* TODO: Add upcoming events and current campaign actions to the homepage. */}

    <section class="section signup-band" id="signup">
      <div>
        <p class="eyebrow">Stay Connected</p>
        <h2>Join Adelaide’s pro-housing community.</h2>
        <p>Get campaign updates, event invitations, and practical opportunities to speak up.</p>
      </div>
      <SignupForm />
    </section>
  </main>
</BaseLayout>
