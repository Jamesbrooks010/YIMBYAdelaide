---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PlanningMap from '@/components/PlanningMap.astro'
import SignupForm from '@/components/SignupForm.astro'

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`
---

<BaseLayout
  title="About | YIMBY Adelaide"
  description="Why YIMBY Adelaide exists and how better planning can deliver more homes, better choices, and a fairer city."
>
  <main>
    <section class="page-hero page-hero--about">
      <p class="eyebrow">About</p>
      <h1>Adelaide should make room for more neighbours.</h1>
      <p>
        YIMBY Adelaide is a local pro-housing community making the case for more homes, better
        choices, and a fairer city—especially in the well-located neighbourhoods where people most
        want to live.
      </p>
      <div class="actions">
        <a class="button" href={`${base}membership`}>Become a member</a>
        <a class="button button--secondary" href="#what-we-do">What we do</a>
      </div>
    </section>

    <section class="section split">
      <div>
        <p class="eyebrow">Why We Started</p>
        <h2>Adelaide is no longer the affordable city we remember.</h2>
      </div>
      <div class="copy-stack">
        <p>
          House prices and rents have risen far beyond what many Adelaideans thought possible.
          Young people are being locked out, while lower-income and vulnerable households face
          greater housing stress and homelessness.
        </p>
        <p>
          High construction costs are part of the problem, but they are not the whole story.
          Planning and zoning rules determine what can be built, where it can be built, and how
          many homes Adelaide can add in response to demand.
        </p>
        <p>
          Too often, strict controls keep high-demand neighbourhoods close to jobs, schools,
          services, and other amenities largely unchanged, pushing new housing to places without
          the same opportunities or existing infrastructure.
        </p>
        <p>
          We started YIMBY Adelaide to make the positive case for change: allowing more apartments,
          townhouses, smaller homes, and other choices in the places people already want to live.
        </p>
      </div>
    </section>

    <section class="section section--map">
      <PlanningMap
        title="What can be built where?"
        description="Explore how minimum subdivision sizes and maximum building heights vary parcel by parcel across metropolitan Adelaide. Switch between the two planning rules below."
      />
    </section>

    <section class="section about-principles" aria-label="YIMBY Adelaide principles">
      <article>
        <p class="eyebrow">01</p>
        <h3>More homes in high-demand neighbourhoods</h3>
        <p>
          Planning should allow more people to live near jobs, transport, universities, schools,
          shops, parks, services, and existing infrastructure.
        </p>
      </article>
      <article>
        <p class="eyebrow">02</p>
          <h3>A fairer share of growth</h3>
          <p>
            Adelaide should not push most new housing to the fringe, renewal areas, or main roads
          while shielding well-served neighbourhoods from change.
        </p>
      </article>
      <article>
        <p class="eyebrow">03</p>
        <h3>Better use of what we already have</h3>
        <p>
          Building in established areas makes better use of existing infrastructure and brings
          more people closer to the opportunities that make a city productive and prosperous.
        </p>
      </article>
    </section>

    <section class="section split" id="what-we-do">
      <div>
        <p class="eyebrow">What We Do</p>
        <h2>Make the case for saying yes.</h2>
      </div>
      <div class="copy-stack">
        <p>
          YIMBY Adelaide exists to articulate the case for embracing the change that comes with
          living in a prosperous capital city. We make the pro-housing majority visible so decision
          makers hear from people who support more homes, not only from people opposing them.
        </p>
        <p>
          We explain the cost of restrictive planning: fewer choices, higher rents and prices,
          longer distances from opportunity, and a greater infrastructure burden as growth is
          forced elsewhere.
        </p>
        <p>
          Our work will include planning submissions, explainers, community events, campaign tools,
          local stories, and clear asks for councils and state government.
        </p>
      </div>
    </section>

    <section class="section values values--about">
      <article>
        <span>01</span>
        <h3>Speak Up</h3>
        <p>Help show that Adelaide has residents who welcome more homes and better housing choices.</p>
      </article>
      <article>
        <span>02</span>
        <h3>Make It Practical</h3>
        <p>Support reforms that turn good intentions into homes people can actually live in.</p>
      </article>
      <article>
        <span>03</span>
        <h3>Build Trust</h3>
        <p>Be transparent, evidence-led, non-partisan, and serious about conflicts of interest.</p>
      </article>
      <article>
        <span>04</span>
        <h3>Stay Local</h3>
        <p>Ground the movement in Adelaide's neighbourhoods, pressures, institutions, and possibilities.</p>
      </article>
    </section>

    <section class="section split about-note">
      <div>
        <p class="eyebrow">What YIMBY Means</p>
        <h2>Yes In My Back Yard.</h2>
      </div>
      <div class="copy-stack">
        <p>
          YIMBY means saying yes to homes, neighbours, and opportunity. It means accepting that a
          successful capital city will change, while working to share the benefits and costs of that
          growth more fairly.
        </p>
        <p>
          It also means being honest about trade-offs. Housing scarcity is not neutral. When we block
          new homes in well-located places, the costs show up as higher rents, longer commutes, more
          displacement, and fewer choices.
        </p>
      </div>
    </section>

    <section class="section signup-band" id="signup">
      <div>
        <p class="eyebrow">Join Us</p>
        <h2>Help build the pro-housing voice Adelaide needs.</h2>
        <p>
          Subscribe for updates, campaign actions, and membership news from YIMBY Adelaide.
        </p>
      </div>
      <SignupForm compact />
    </section>
  </main>
</BaseLayout>
