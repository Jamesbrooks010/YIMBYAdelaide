---
import 'maplibre-gl/dist/maplibre-gl.css'
import {PLANNING_MAP_LAYERS} from '@/lib/planningMapLayers'

interface Props {
  id?: string
  layerId?: keyof typeof PLANNING_MAP_LAYERS
  title: string
  description: string
}

const {
  id = 'planning-map',
  layerId = 'minimumLot',
  title,
  description
} = Astro.props

const layer = PLANNING_MAP_LAYERS[layerId]
---

<section class="planning-map" aria-labelledby={`${id}-title`}>
  <div class="planning-map__intro">
    <div>
      <p class="eyebrow">Explore the rules</p>
      <h2 id={`${id}-title`}>{title}</h2>
    </div>
    <p>{description}</p>
  </div>

  <div class="planning-map__frame">
    <div
      class="planning-map__canvas"
      id={id}
      data-planning-map
      data-layer={layerId}
      role="region"
      aria-label={`${title}. Interactive map. Use the controls to zoom and drag to move around Adelaide.`}
    ></div>

    <div class="planning-map__status" data-map-status role="status" aria-live="polite">
      <span class="planning-map__spinner" aria-hidden="true"></span>
      <span data-map-status-text>Loading planning map…</span>
      <button class="planning-map__retry" type="button" data-map-retry hidden>Try again</button>
    </div>

    <aside class="planning-map__legend" aria-label={`${layer.legendTitle} legend`}>
      <div class="planning-map__legend-heading">
        <strong>{layer.legendTitle}</strong>
        <span>{layer.legendSubtitle}</span>
      </div>
      <ul>
        {layer.legend.map((item) => (
          <li>
            <span class="planning-map__swatch" style={`--legend-colour: ${item.colour}`}></span>
            <span>{item.label}</span>
          </li>
        ))}
      </ul>
    </aside>
  </div>

  <div class="planning-map__note">
    <p>Click or tap a parcel to see its category. Boundaries and values are indicative.</p>
    <p>Source: South Australian parcel and planning data.</p>
  </div>
</section>

<script>
  import maplibregl from 'maplibre-gl'
  import {Protocol} from 'pmtiles'
  import {PLANNING_MAP_LAYERS} from '@/lib/planningMapLayers'

  const protocol = new Protocol()
  maplibregl.addProtocol('pmtiles', protocol.tile)

  function initialiseMap(container: HTMLElement) {
    const layer = PLANNING_MAP_LAYERS[container.dataset.layer ?? 'minimumLot']
    const fallback = layer.legend.find((item) => item.value === 0) ?? layer.legend[0]
    const labels = Object.fromEntries(layer.legend.map((item) => [item.value, item.label]))
    const colourStops = layer.legend
      .filter((item) => item.value !== fallback.value)
      .flatMap((item) => [item.value, item.colour])
    const colourExpression = [
      'match',
      ['get', layer.property],
      ...colourStops,
      fallback.colour
    ] as maplibregl.ExpressionSpecification
    const fillLayerId = `${layer.id}-fill`
    const frame = container.closest('.planning-map__frame') as HTMLElement
    const status = frame.querySelector('[data-map-status]') as HTMLElement
    const statusText = frame.querySelector('[data-map-status-text]') as HTMLElement
    const retry = frame.querySelector('[data-map-retry]') as HTMLButtonElement
    let map: maplibregl.Map | undefined
    let settled = false

    const showError = () => {
      if (settled) return
      status.dataset.state = 'error'
      statusText.textContent = 'The parcel layer could not be loaded.'
      retry.hidden = false
    }

    const start = () => {
      settled = false
      retry.hidden = true
      status.dataset.state = 'loading'
      statusText.textContent = 'Loading planning map…'
      map?.remove()

      const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`
      const archiveUrl = new URL(`${baseUrl}${layer.archive}`, window.location.origin).href
      map = new maplibregl.Map({
        container,
        style: {
          version: 8,
          sources: {
            basemap: {
              type: 'raster',
              tiles: [
                'https://a.basemaps.cartocdn.com/light_all/{z}/{x}/{y}@2x.png',
                'https://b.basemaps.cartocdn.com/light_all/{z}/{x}/{y}@2x.png',
                'https://c.basemaps.cartocdn.com/light_all/{z}/{x}/{y}@2x.png'
              ],
              tileSize: 256,
              attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>'
            },
            parcels: {
              type: 'vector',
              url: `pmtiles://${archiveUrl}`,
              attribution: 'South Australian parcel and planning data'
            }
          },
          layers: [
            {id: 'basemap', type: 'raster', source: 'basemap', paint: {'raster-opacity': 0.72, 'raster-saturation': -0.72}},
            {
              id: fillLayerId,
              type: 'fill',
              source: 'parcels',
              'source-layer': layer.sourceLayer,
              minzoom: 10.8,
              paint: {
                'fill-color': colourExpression,
                'fill-opacity': ['interpolate', ['linear'], ['zoom'], 10, 0.76, 15, 0.88],
                'fill-outline-color': ['interpolate', ['linear'], ['zoom'], 11, 'rgba(255,255,255,0.08)', 15, 'rgba(72,78,75,0.46)']
              }
            }
          ]
        },
        center: [138.6007, -34.9285],
        zoom: 12.5,
        minZoom: 10.8,
        maxZoom: 18,
        maxPitch: 0,
        attributionControl: false
      })

      map.addControl(new maplibregl.NavigationControl({showCompass: false}), 'top-right')
      map.addControl(new maplibregl.AttributionControl({compact: true}), 'bottom-right')

      map.once('idle', () => {
        settled = true
        status.dataset.state = 'ready'
      })

      map.on('error', (event) => {
        console.error('Planning map error', event.error)
        showError()
      })

      map.on('click', (event) => {
        const hitArea: [[number, number], [number, number]] = [
          [event.point.x - 6, event.point.y - 6],
          [event.point.x + 6, event.point.y + 6]
        ]
        const features = map!.queryRenderedFeatures(hitArea, {layers: [fillLayerId]})
        const feature = features[0]
        if (!feature) return
        const category = Number(feature.properties?.[layer.property] ?? fallback.value)
        new maplibregl.Popup({closeButton: true, closeOnClick: true, offset: 8})
          .setLngLat(event.lngLat)
          .setHTML(`<strong>${layer.popupTitle}</strong><span>${labels[category] ?? fallback.label}</span>`)
          .addTo(map!)
      })

      map.on('mouseenter', fillLayerId, () => {
        map!.getCanvas().style.cursor = 'pointer'
      })
      map.on('mouseleave', fillLayerId, () => {
        map!.getCanvas().style.cursor = ''
      })
    }

    retry.addEventListener('click', start)
    start()
  }

  document.querySelectorAll<HTMLElement>('[data-planning-map]').forEach(initialiseMap)
</script>
