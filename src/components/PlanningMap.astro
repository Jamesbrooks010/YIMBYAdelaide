---
import 'maplibre-gl/dist/maplibre-gl.css'
import {PLANNING_MAP_LAYERS} from '@/lib/planningMapLayers'

interface Props {
  id?: string
  title: string
  description: string
}

const {
  id = 'planning-map',
  title,
  description
} = Astro.props

const layerIds = ['minimumLot', 'maximumHeight'] as const
const layers = layerIds.map((layerId) => [layerId, PLANNING_MAP_LAYERS[layerId]] as const)
const initialLayer = layers[0][1]
---

<section class="planning-map" aria-labelledby={`${id}-title`}>
  <div class="planning-map__intro">
    <div>
      <p class="eyebrow">Explore the rules</p>
      <h2 id={`${id}-title`}>{title}</h2>
    </div>
    <p>{description}</p>
  </div>

  <div class="planning-map__switcher" role="group" aria-label="Choose a planning rule to display">
    {layers.map(([layerId, layer], index) => (
      <button
        type="button"
        data-map-layer-button={layerId}
        aria-pressed={index === 0 ? 'true' : 'false'}
      >
        {layer.switchLabel}
      </button>
    ))}
  </div>

  <div class="planning-map__frame">
    <div
      class="planning-map__canvas"
      id={id}
      data-planning-map
      role="region"
      aria-label={`${title}. Interactive map. Use the controls to zoom and drag to move around Adelaide.`}
    ></div>

    <div class="planning-map__status" data-map-status role="status" aria-live="polite">
      <span class="planning-map__spinner" aria-hidden="true"></span>
      <span data-map-status-text>Loading planning map…</span>
      <button class="planning-map__retry" type="button" data-map-retry hidden>Try again</button>
    </div>

    <aside class="planning-map__legend" aria-label={`${initialLayer.legendTitle} legend`} data-map-legend>
      <div class="planning-map__legend-heading">
        <strong data-map-legend-title>{initialLayer.legendTitle}</strong>
        <span data-map-legend-subtitle>{initialLayer.legendSubtitle}</span>
      </div>
      <ul data-map-legend-items>
        {initialLayer.legend.map((item) => (
          <li>
            <span class="planning-map__swatch" style={`--legend-colour: ${item.colour}`}></span>
            <span>{item.label}</span>
          </li>
        ))}
      </ul>
    </aside>
  </div>

  <div class="planning-map__note">
    <p>Click or tap a parcel to see its category. Boundaries and values are indicative.</p>
    <p>Source: South Australian parcel and planning data.</p>
  </div>
</section>

<script>
  import maplibregl from 'maplibre-gl'
  import {Protocol} from 'pmtiles'
  import {PLANNING_MAP_LAYERS} from '@/lib/planningMapLayers'

  const protocol = new Protocol()
  maplibregl.addProtocol('pmtiles', protocol.tile)

  function initialiseMap(container: HTMLElement) {
    const layerIds = ['minimumLot', 'maximumHeight'] as const
    type LayerId = typeof layerIds[number]
    let activeLayerId: LayerId = 'minimumLot'
    let activeLayer = PLANNING_MAP_LAYERS[activeLayerId]
    const frame = container.closest('.planning-map__frame') as HTMLElement
    const section = container.closest('.planning-map') as HTMLElement
    const status = frame.querySelector('[data-map-status]') as HTMLElement
    const statusText = frame.querySelector('[data-map-status-text]') as HTMLElement
    const retry = frame.querySelector('[data-map-retry]') as HTMLButtonElement
    const legend = frame.querySelector('[data-map-legend]') as HTMLElement
    const legendTitle = legend.querySelector('[data-map-legend-title]') as HTMLElement
    const legendSubtitle = legend.querySelector('[data-map-legend-subtitle]') as HTMLElement
    const legendItems = legend.querySelector('[data-map-legend-items]') as HTMLElement
    const layerButtons = section.querySelectorAll<HTMLButtonElement>('[data-map-layer-button]')
    const layerState = Object.fromEntries(layerIds.map((layerId) => {
      const layer = PLANNING_MAP_LAYERS[layerId]
      const fallback = layer.legend.find((item) => item.value === 0) ?? layer.legend[0]
      const labels = Object.fromEntries(layer.legend.map((item) => [item.value, item.label]))
      const colourStops = layer.legend
        .filter((item) => item.value !== fallback.value)
        .flatMap((item) => [item.value, item.colour])
      return [layerId, {
        layer,
        fallback,
        labels,
        sourceId: `${layer.id}-parcels`,
        fillLayerId: `${layer.id}-fill`,
        colourExpression: ['match', ['get', layer.property], ...colourStops, fallback.colour] as maplibregl.ExpressionSpecification
      }]
    })) as Record<LayerId, {
      layer: typeof activeLayer
      fallback: typeof activeLayer.legend[number]
      labels: Record<number, string>
      sourceId: string
      fillLayerId: string
      colourExpression: maplibregl.ExpressionSpecification
    }>
    let map: maplibregl.Map | undefined
    let popup: maplibregl.Popup | undefined
    let settled = false

    const renderLegend = () => {
      legend.setAttribute('aria-label', `${activeLayer.legendTitle} legend`)
      legendTitle.textContent = activeLayer.legendTitle
      legendSubtitle.textContent = activeLayer.legendSubtitle
      legendItems.replaceChildren(...activeLayer.legend.map((item) => {
        const row = document.createElement('li')
        const swatch = document.createElement('span')
        const label = document.createElement('span')
        swatch.className = 'planning-map__swatch'
        swatch.style.setProperty('--legend-colour', item.colour)
        label.textContent = item.label
        row.append(swatch, label)
        return row
      }))
    }

    const selectLayer = (layerId: LayerId) => {
      if (!map || layerId === activeLayerId) return
      popup?.remove()
      map.setLayoutProperty(layerState[activeLayerId].fillLayerId, 'visibility', 'none')
      activeLayerId = layerId
      activeLayer = PLANNING_MAP_LAYERS[activeLayerId]
      map.setLayoutProperty(layerState[activeLayerId].fillLayerId, 'visibility', 'visible')
      layerButtons.forEach((button) => {
        button.setAttribute('aria-pressed', String(button.dataset.mapLayerButton === activeLayerId))
      })
      renderLegend()
    }

    const showError = () => {
      if (settled) return
      status.dataset.state = 'error'
      statusText.textContent = 'The parcel layer could not be loaded.'
      retry.hidden = false
    }

    const start = () => {
      settled = false
      retry.hidden = true
      status.dataset.state = 'loading'
      statusText.textContent = 'Loading planning map…'
      map?.remove()

      const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`
      const parcelSources = Object.fromEntries(layerIds.map((layerId) => {
        const state = layerState[layerId]
        const archiveUrl = new URL(`${baseUrl}${state.layer.archive}`, window.location.origin).href
        return [state.sourceId, {
          type: 'vector',
          url: `pmtiles://${archiveUrl}`,
          attribution: 'South Australian parcel and planning data'
        }]
      }))
      const parcelLayers = layerIds.map((layerId) => {
        const state = layerState[layerId]
        return {
          id: state.fillLayerId,
          type: 'fill' as const,
          source: state.sourceId,
          'source-layer': state.layer.sourceLayer,
          minzoom: 10.8,
          layout: {visibility: layerId === activeLayerId ? 'visible' as const : 'none' as const},
          paint: {
            'fill-color': state.colourExpression,
            'fill-opacity': ['interpolate', ['linear'], ['zoom'], 10, 0.76, 15, 0.88] as maplibregl.ExpressionSpecification,
            'fill-outline-color': ['interpolate', ['linear'], ['zoom'], 11, 'rgba(255,255,255,0.08)', 15, 'rgba(72,78,75,0.46)'] as maplibregl.ExpressionSpecification
          }
        }
      })
      map = new maplibregl.Map({
        container,
        style: {
          version: 8,
          sources: {
            basemap: {
              type: 'raster',
              tiles: [
                'https://a.basemaps.cartocdn.com/light_all/{z}/{x}/{y}@2x.png',
                'https://b.basemaps.cartocdn.com/light_all/{z}/{x}/{y}@2x.png',
                'https://c.basemaps.cartocdn.com/light_all/{z}/{x}/{y}@2x.png'
              ],
              tileSize: 256,
              attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>'
            },
            ...parcelSources
          },
          layers: [
            {id: 'basemap', type: 'raster', source: 'basemap', paint: {'raster-opacity': 0.72, 'raster-saturation': -0.72}},
            ...parcelLayers
          ]
        },
        center: [138.6007, -34.9285],
        zoom: 12.5,
        minZoom: 10.8,
        maxZoom: 18,
        maxPitch: 0,
        attributionControl: false
      })

      map.addControl(new maplibregl.NavigationControl({showCompass: false}), 'top-right')
      map.addControl(new maplibregl.AttributionControl({compact: true}), 'bottom-right')

      map.once('idle', () => {
        settled = true
        status.dataset.state = 'ready'
      })

      map.on('error', (event) => {
        console.error('Planning map error', event.error)
        showError()
      })

      map.on('click', (event) => {
        const state = layerState[activeLayerId]
        const hitArea: [[number, number], [number, number]] = [
          [event.point.x - 6, event.point.y - 6],
          [event.point.x + 6, event.point.y + 6]
        ]
        const features = map!.queryRenderedFeatures(hitArea, {layers: [state.fillLayerId]})
        const feature = features[0]
        if (!feature) return
        const category = Number(feature.properties?.[state.layer.property] ?? state.fallback.value)
        popup = new maplibregl.Popup({closeButton: true, closeOnClick: true, offset: 8})
          .setLngLat(event.lngLat)
          .setHTML(`<strong>${state.layer.popupTitle}</strong><span>${state.labels[category] ?? state.fallback.label}</span>`)
          .addTo(map!)
      })

      layerIds.forEach((layerId) => {
        const fillLayerId = layerState[layerId].fillLayerId
        map!.on('mouseenter', fillLayerId, () => {
          map!.getCanvas().style.cursor = 'pointer'
        })
        map!.on('mouseleave', fillLayerId, () => {
          map!.getCanvas().style.cursor = ''
        })
      })
    }

    layerButtons.forEach((button) => {
      button.addEventListener('click', () => selectLayer(button.dataset.mapLayerButton as LayerId))
    })
    retry.addEventListener('click', start)
    start()
  }

  document.querySelectorAll<HTMLElement>('[data-planning-map]').forEach(initialiseMap)
</script>
