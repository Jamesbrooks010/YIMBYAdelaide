---
interface Props {
  compact?: boolean
  form?: 'signup' | 'membership'
}

const {compact = false, form = 'signup'} = Astro.props
const embeds = {
  signup: {
    scriptUrl:
      import.meta.env.PUBLIC_ACTION_NETWORK_SCRIPT_URL ||
      'https://actionnetwork.org/widgets/v6/form/sign-up-to-yimby-adelaide?format=js&source=widget',
    targetId:
      import.meta.env.PUBLIC_ACTION_NETWORK_TARGET_ID ||
      'can-form-area-sign-up-to-yimby-adelaide',
    pageUrl: 'https://actionnetwork.org/forms/sign-up-to-yimby-adelaide'
  },
  membership: {
    scriptUrl:
      import.meta.env.PUBLIC_ACTION_NETWORK_MEMBERSHIP_SCRIPT_URL ||
      'https://actionnetwork.org/widgets/v6/form/become-a-member-of-yimby-adelaide?format=js&source=widget',
    targetId:
      import.meta.env.PUBLIC_ACTION_NETWORK_MEMBERSHIP_TARGET_ID ||
      'can-form-area-become-a-member-of-yimby-adelaide',
    pageUrl: 'https://actionnetwork.org/forms/become-a-member-of-yimby-adelaide'
  }
}
const actionNetworkEmbed = {
  scriptUrl: embeds[form].scriptUrl,
  targetId: embeds[form].targetId
}
---

{
  actionNetworkEmbed ? (
    <div class:list={['signup-form action-network-signup', compact && 'signup-form--compact']}>
      <link href="https://actionnetwork.org/css/style-embed-v3.css" rel="stylesheet" type="text/css" />
      <script is:inline src={actionNetworkEmbed.scriptUrl}></script>
      <div id={actionNetworkEmbed.targetId} style="width: 100%">
        <!-- Action Network inserts the embedded form here. -->
      </div>
      <p class="signup-form__fallback">
        Form not loading? <a href={actionNetworkEmbed.pageUrl} target="_blank" rel="noreferrer">Open it directly on Action Network</a>.
      </p>
    </div>
  ) : (
    <form
      class:list={['signup-form', compact && 'signup-form--compact']}
      name="supporter-signup"
      method="post"
      data-netlify="true"
    >
      <input type="hidden" name="form-name" value="supporter-signup" />
      <label>
        <span>Name</span>
        <input name="name" type="text" autocomplete="name" placeholder="Your name" />
      </label>
      <label>
        <span>Email</span>
        <input name="email" type="email" autocomplete="email" placeholder="you@example.com" required />
      </label>
      <label>
        <span>Postcode</span>
        <input name="postcode" type="text" inputmode="numeric" autocomplete="postal-code" placeholder="5000" />
      </label>
      <button type="submit">Join the list</button>
      <p>We will use this to send occasional YIMBY Adelaide updates. Payment support will come later.</p>
    </form>
  )
}
