---
import SignupForm from '@/components/SignupForm.astro'

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`
---

<section class="membership-journey" data-membership-journey aria-labelledby="membership-journey-title">
  <div class="membership-journey__intro">
    <p class="eyebrow">Member Signup</p>
    <h1 id="membership-journey-title">Become a member.</h1>
    <p>
      A short, three-step process covering our probity commitments, your member details, and an
      optional opportunity to support the work.
    </p>
  </div>

  <ol class="membership-journey__steps" aria-label="Membership signup progress">
    <li data-journey-indicator aria-current="step">
      <button type="button" data-journey-step="0" aria-controls="probity-step">
        <span>1</span><strong>Probity</strong>
      </button>
    </li>
    <li data-journey-indicator>
      <button type="button" data-journey-step="1" aria-controls="details-step" disabled>
        <span>2</span><strong>Your details</strong>
      </button>
    </li>
    <li data-journey-indicator>
      <button type="button" data-journey-step="2" aria-controls="donation-step" disabled>
        <span>3</span><strong>Consider donating</strong>
      </button>
    </li>
  </ol>

  <div class="membership-journey__panel" id="probity-step" data-journey-panel>
    <div class="membership-journey__card">
      <p class="eyebrow">Step 1 of 3</p>
      <h2>Probity commitments</h2>
      <p>Please acknowledge both commitments before continuing to the membership form.</p>
      <fieldset class="membership-journey__checks">
        <legend>I acknowledge that:</legend>
        <label>
          <input type="checkbox" data-probity-checkbox />
          <span>I will disclose relevant actual or potential conflicts of interest.</span>
        </label>
        <label>
          <input type="checkbox" data-probity-checkbox />
          <span>I will not seek special treatment or influence for a personal or financial interest.</span>
        </label>
      </fieldset>
      <p class="membership-journey__status" data-probity-status role="status" aria-live="polite">
        Acknowledge both commitments to continue.
      </p>
      <div class="membership-journey__actions">
        <a class="button button--secondary" href={`${base}membership/`}>Back to membership</a>
        <button class="button" type="button" data-probity-next disabled>Continue to your details</button>
      </div>
    </div>
  </div>

  <div class="membership-journey__panel" id="details-step" data-journey-panel hidden>
    <div class="membership-journey__details-copy">
      <p class="eyebrow">Step 2 of 3</p>
      <h2>Your member details</h2>
      <p>
        Complete the membership form below. This is separate from the general email list so member
        records remain distinct.
      </p>
      <p class="membership-journey__integration-note">
        The probity acknowledgements are not yet written to Action Network. We will connect them
        once the final policy wording and custom fields are approved.
      </p>
    </div>
    <SignupForm compact form="membership" />
    <div class="membership-journey__actions membership-journey__actions--details">
      <button class="button button--secondary" type="button" data-journey-back>Back to probity</button>
      <button class="button" type="button" data-details-complete>I’ve completed the form — continue</button>
    </div>
  </div>

  <div class="membership-journey__panel" id="donation-step" data-journey-panel hidden>
    <div class="membership-journey__card">
      <p class="eyebrow">Step 3 of 3</p>
      <h2>Consider supporting the work.</h2>
      <p>
        Member donations will help fund research, submissions, community events, campaign tools,
        design, hosting, and the administration that keeps advocacy going.
      </p>
      <p class="membership-journey__integration-note">
        We are still designing this part of the journey. No donation or payment is collected on
        this page yet.
      </p>
      <div class="membership-journey__actions">
        <button class="button button--secondary" type="button" data-journey-back>Back to your details</button>
        <a class="button" href={`${base}membership/`}>Finish</a>
      </div>
    </div>
  </div>
</section>

<script>
  function initialiseMembershipJourney(journey: HTMLElement) {
    const panels = Array.from(journey.querySelectorAll<HTMLElement>('[data-journey-panel]'))
    const indicators = Array.from(journey.querySelectorAll<HTMLElement>('[data-journey-indicator]'))
    const stepButtons = Array.from(journey.querySelectorAll<HTMLButtonElement>('[data-journey-step]'))
    const checkboxes = Array.from(journey.querySelectorAll<HTMLInputElement>('[data-probity-checkbox]'))
    const probityNext = journey.querySelector<HTMLButtonElement>('[data-probity-next]')
    const detailsComplete = journey.querySelector<HTMLButtonElement>('[data-details-complete]')
    const status = journey.querySelector<HTMLElement>('[data-probity-status]')
    let activeStep = 0

    const showStep = (step: number) => {
      activeStep = Math.max(0, Math.min(step, panels.length - 1))
      panels.forEach((panel, index) => { panel.hidden = index !== activeStep })
      indicators.forEach((indicator, index) => {
        if (index === activeStep) indicator.setAttribute('aria-current', 'step')
        else indicator.removeAttribute('aria-current')
      })
      journey.scrollIntoView({behavior: 'smooth', block: 'start'})
    }

    const updateProbityState = () => {
      const acknowledged = checkboxes.every((checkbox) => checkbox.checked)
      if (probityNext) probityNext.disabled = !acknowledged
      if (stepButtons[1]) stepButtons[1].disabled = !acknowledged
      if (status) {
        status.textContent = acknowledged
          ? 'Both commitments acknowledged.'
          : 'Acknowledge both commitments to continue.'
      }
    }

    probityNext?.addEventListener('click', () => showStep(1))
    detailsComplete?.addEventListener('click', () => {
      if (stepButtons[2]) stepButtons[2].disabled = false
      showStep(2)
    })
    journey.querySelectorAll<HTMLButtonElement>('[data-journey-back]').forEach((button) => {
      button.addEventListener('click', () => showStep(activeStep - 1))
    })
    stepButtons.forEach((button) => {
      button.addEventListener('click', () => showStep(Number(button.dataset.journeyStep)))
    })
    checkboxes.forEach((checkbox) => checkbox.addEventListener('change', updateProbityState))
    updateProbityState()
  }

  document.querySelectorAll<HTMLElement>('[data-membership-journey]').forEach(initialiseMembershipJourney)
</script>
